NODE_ENV=staging
LOG_LEVEL=info

# Public URLs
API_PUBLIC_URL=https://api-staging.example.com
FRONTEND_PUBLIC_URL=https://studio-staging.example.com
WEBHOOK_PUBLIC_URL=https://api-staging.example.com

# Ports
PORT=3001
FRONTEND_PORT=4173

# CORS
CORS_ORIGIN=https://studio-staging.example.com

# Trusted proxy auth for staging/production
AUTH_TRUST_MODE=signed-headers
AUTH_PROXY_SHARED_SECRET=replace-with-long-random-secret
AUTH_PROXY_SIGNATURE_TTL_MS=300000

# JWT / session / encryption
JWT_SECRET=replace-with-long-random-secret
APP_ENCRYPTION_KEY=replace-with-32-byte-hex-or-base64-key

# Database / cache
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/cubo_ai_studio?schema=public
REDIS_URL=redis://redis:6379

# AI provider defaults / fallback
AI_RUNTIME_ENABLED=false
AI_PROVIDER=openai-compatible
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_API_KEY=
AI_REQUEST_TIMEOUT_MS=30000
# Optional per-assistant RAG thresholds; preserve 0.70 for all other assistants.
ASSISTANT_KNOWLEDGE_MIN_SCORE_OVERRIDES=cmrcunljc008rrq01d7urn2t5:0.55
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Chatwoot
CHATWOOT_URL=https://chatwoot.example.com
CHATWOOT_TOKEN=
CHATWOOT_ALLOW_INSECURE_WEBHOOKS=false
CHATWOOT_ATTACHMENT_DOWNLOAD_TIMEOUT_MS=15000
CHATWOOT_ATTACHMENT_MAX_IMAGE_BYTES=10485760
CHATWOOT_ATTACHMENT_MAX_AUDIO_BYTES=20971520
CHATWOOT_ATTACHMENT_MAX_VIDEO_BYTES=20971520
CHATWOOT_ATTACHMENT_MAX_DOCUMENT_BYTES=15728640

# Google Calendar OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=https://api-staging.example.com/apps/google-calendar/oauth/callback

# Frontend build
VITE_API_URL=https://api-staging.example.com
VITE_PUBLIC_API_URL=https://api-staging.example.com
VITE_APP_PUBLIC_API_URL=https://api-staging.example.com
VITE_API_PUBLIC_URL=https://api-staging.example.com
