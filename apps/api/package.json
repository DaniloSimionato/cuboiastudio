{
  "name": "@cubo-ai-studio/api",
  "private": true,
  "version": "0.1.0",
  "type": "commonjs",
  "prisma": {
    "seed": "node --experimental-strip-types prisma/seed.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "start": "node dist/main.js",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:format": "prisma format --schema prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema prisma/schema.prisma",
    "prisma:migrate": "node scripts/run-prisma-migrate.mjs",
    "prisma:seed": "node --experimental-strip-types prisma/seed.ts",
    "db:check": "node scripts/validate-db.mjs",
    "db:seed": "npm run prisma:seed",
    "staging:bootstrap-admin": "node scripts/bootstrap-staging-admin.js",
    "cleanup:smoke": "node scripts/cleanup-staging-smoke-data.mjs",
    "test:apps": "npm run build && node --test test/app-store.test.mjs test/assistant-calendar-tools.test.mjs",
    "test:attachments": "npm run build && node --test test/attachment-pipeline.test.mjs",
    "test:chatwoot": "npm run build && node --test test/chatwoot-webhook-and-runtime.test.mjs",
    "test:studio-users": "npm run build && node --test test/studio-users-auth.test.mjs"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@prisma/client": "^6.16.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "nestjs-pino": "^4.2.0",
    "openai": "^6.45.0",
    "pdf-parse": "^2.4.5",
    "pino": "^9.7.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^22.16.5",
    "prisma": "^6.16.0",
    "typescript": "^5.8.3"
  }
}
