NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=debug

# Backend auth / session signing
JWT_SECRET=
AUTH_TRUST_MODE=off
AUTH_PROXY_SHARED_SECRET=
AUTH_PROXY_SIGNATURE_TTL_MS=300000

# Tenant/app secret encryption (32 bytes em hex/base64)
APP_ENCRYPTION_KEY=

# Database / cache
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/cubo_ai_studio?schema=public
REDIS_URL=redis://localhost:6379

# AI provider defaults / fallback
AI_RUNTIME_ENABLED=false
AI_PROVIDER=openai-compatible
AI_BASE_URL=
AI_MODEL=
AI_API_KEY=
AI_REQUEST_TIMEOUT_MS=30000
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Chatwoot / CuboChat
CHATWOOT_URL=http://localhost:3000
CHATWOOT_TOKEN=
CHATWOOT_ALLOW_INSECURE_WEBHOOKS=false
CHATWOOT_ATTACHMENT_DOWNLOAD_TIMEOUT_MS=15000
CHATWOOT_ATTACHMENT_MAX_IMAGE_BYTES=10485760
CHATWOOT_ATTACHMENT_MAX_AUDIO_BYTES=20971520
CHATWOOT_ATTACHMENT_MAX_VIDEO_BYTES=20971520
CHATWOOT_ATTACHMENT_MAX_DOCUMENT_BYTES=15728640

# Google Calendar OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=

# Frontend
VITE_API_URL=http://localhost:3001
VITE_PUBLIC_API_URL=
VITE_APP_PUBLIC_API_URL=
VITE_API_PUBLIC_URL=
